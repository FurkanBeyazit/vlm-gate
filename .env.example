# Bu dosyayı `.env` olarak kopyala ve gerçek değerlerle doldur.
# `.env` git'e commit'lenmemeli (varsa .gitignore'a ekle).
#
# Çalışma akışı:
#   - Geliştirme/test: hiçbir şey değiştirme, default'lar localhost
#   - Pazartesi LAN testi: VLM_GATE_BASE_URL'i kendi makinenin IP'siyle güncelle
#   - VMS hazır olunca: VMS_URL'i Go Sejun'un verdiği URL'e güncelle, fake_vms.py'ı kapat

# Bizim VLM-GATE'in dış dünyadan görüldüğü URL.
# LLM bunu kullanır (trigger + stream + image).
# Default: http://127.0.0.1:8000  (localhost only)
VLM_GATE_BASE_URL=http://127.0.0.1:8000

# VMS'in trigger'ı dinlediği URL.
# Geliştirme alternatifi: http://127.0.0.1:8001/from-vlm-gate (fake_vms.py)
VMS_URL=http://127.0.0.1:8001/from-vlm-gate

# VLM endpoint — Park Hoonbeom'un servisi.
# Sadece fake_vms.py kullanır. Gerçek VMS kendi config'inde tutar.
VLM_URL=http://127.0.0.1:8001/describe

# Image dosyalarının kök dizini — /image API bu altta serve eder.
VLM_GATE_IMAGE_ROOT=Z:\

# VLM base64 image gönderirse buraya kaydedilir → path → /image URL.
# IMAGE_ROOT altında olmalı.
VLM_GATE_IMAGE_CACHE=Z:\vlm_gate_cache

# Fake VMS örnek görsel kaynağı (klasör veya dosya)
SAMPLE_IMAGE_PATH=Z:\20260422\20897
